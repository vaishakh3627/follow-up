PORT=3000

# Gemini AI extraction
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Where reminders should be delivered to YOU
ALERT_EMAIL_TO=you@example.com
ALERT_PHONE_TO=+919000000000

# Email notifications (required if notify by email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_password_or_app_password
EMAIL_FROM=Follow-up Bot <your_email@example.com>

# SMS notifications via Twilio (required if notify by SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
